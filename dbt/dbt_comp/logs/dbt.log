  create  table "ecg_dw"."dev"."dim_admissions__dbt_tmp"
  
  
    as
  
  (
    
WITH admissions AS (

    SELECT 
    md5(cast(coalesce(cast(ed_stay_id as TEXT), '') || '-' || coalesce(cast(ed_hadm_id as TEXT), '') || '-' || coalesce(cast(hosp_hadm_id as TEXT), '') as TEXT)) AS admission_key,
    ed_stay_id,
    ed_hadm_id,
    hosp_hadm_id
    FROM 
    "ecg_dw"."import"."ecgcsv"
)

select 
    admission_key,
    ed_stay_id,
    ed_hadm_id,
    hosp_hadm_id
from admissions
  );
  
